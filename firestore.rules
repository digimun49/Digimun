rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    match /stats/signalCount {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.count == resource.data.count + 1;
    }
    
    match /tickets/{ticketId} {
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message', 'status', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 320
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.subject is string
        && request.resource.data.subject.size() > 0
        && request.resource.data.subject.size() <= 500
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000
        && request.resource.data.status == "open";
      allow read: if request.auth != null
        && (
          resource.data.email == request.auth.token.email
          || isAdmin()
        );
      allow update: if request.auth != null
        && (
          resource.data.email == request.auth.token.email
          || isAdmin()
        );
      allow delete: if request.auth != null && isAdmin();
    }
    
    match /reviews/{reviewId} {
      allow create: if request.resource.data.status == "pending"
        && request.resource.data.keys().hasAll(['name', 'text', 'rating', 'status'])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow read: if resource.data.status == "approved";
      allow read, update, delete: if request.auth != null && isAdmin();
    }
    
    match /users/{userEmail} {
      allow create: if request.auth != null
        && request.auth.token.email.lower() == userEmail.lower()
        && request.resource.data.status == "approved"
        && request.resource.data.paymentStatus == "pending"
        && request.resource.data.quotexStatus == "pending"
        && request.resource.data.digimaxStatus == "pending"
        && request.resource.data.recoveryRequest == "pending"
        && request.resource.data.DigimunXAdv == "pending";
      
      allow read: if request.auth != null
        && request.auth.token.email.lower() == userEmail.lower();
      
      allow update: if request.auth != null
        && request.auth.token.email.lower() == userEmail.lower()
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['paymentStatus', 'quotexStatus', 'digimaxStatus', 'recoveryRequest', 'status', 'approvedAt', 'lockedAt', 'accountStatus', 'DigimunXAdv']);
      
      allow read, write: if request.auth != null && isAdmin();
    }
    
    match /deletedAccounts/{email} {
      allow read: if request.auth != null
        && (
          request.auth.token.email.lower() == email.lower()
          || isAdmin()
        );
      allow write: if false;
    }
    
    match /pageVisits/{visitId} {
      allow create: if request.resource.data.keys().hasAll(['page', 'source', 'timestamp', 'visitorId'])
        && request.resource.data.keys().size() <= 7
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 200
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 100
        && request.resource.data.visitorId is string
        && request.resource.data.visitorId.size() <= 100;
      allow read: if request.auth != null && isAdmin();
    }
    
    match /activeVisitors/{visitorId} {
      allow create, update: if request.resource.data.keys().hasOnly(['page', 'source', 'lastSeen'])
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 200
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 100;
      allow delete: if true;
      allow read: if request.auth != null && isAdmin();
    }
    
    match /admin2faSessions/{sessionId} {
      allow read, write: if false;
    }

    match /adminLogs/{logId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }
    
    match /auditLog/{logId} {
      allow read, write: if false;
    }
    
    match /flaggedSignups/{flagId} {
      allow read, write: if false;
    }
  }
}
